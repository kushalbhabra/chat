{
  "name": "@chat-adapter/teamssdk",
  "version": "0.1.0",
  "description": "Microsoft Teams SDK adapter for chat (teams.ts event-routing abstraction)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@chat-adapter/shared": "^4.18.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "botbuilder": "^4.23.1",
    "botframework-connector": "^4.23.3",
    "chat": "^4.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kushalbhabra/chat.git",
    "directory": "packages/adapter-teamssdk"
  },
  "homepage": "https://github.com/kushalbhabra/chat#readme",
  "bugs": {
    "url": "https://github.com/kushalbhabra/chat/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "chat",
    "teams",
    "microsoft",
    "bot",
    "adapter",
    "teamssdk"
  ],
  "license": "MIT"
}
